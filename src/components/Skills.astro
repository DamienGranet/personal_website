---
import profile from '../data/profile.json';
const groups = profile.skills ?? [];
---
{profile.sections.skills && groups.length > 0 && (
  <section class="block" id="skills" aria-labelledby="skills-heading">
    <div class="wrap">
      <p class="eyebrow">Skills</p>
      <h2 id="skills-heading">What I work with</h2>
      <div class="skill-groups">
        {groups.map((group) => (
          <div class="skill-group">
            <h3>{group.category}</h3>
            <ul class="tags">
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
